<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="20dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/districtName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/district_text"
        android:layout_marginBottom="4dp" />

    <pl.waw.oledzki.wptr.PlateLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/plate_background">

        <!-- EU blue stripe -->
        <LinearLayout
            android:layout_width="28dp"
            android:layout_height="match_parent"
            android:background="@drawable/eu_stripe_background"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★★★★\n★  ★\n★★★★"
                android:textColor="@color/eu_stars"
                android:textSize="4sp"
                android:lineSpacingExtra="-2dp"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PL"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Plate number -->
        <pl.waw.oledzki.wptr.PlateTextView
            android:id="@+id/plateNumber"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48sp"
            android:paddingStart="10dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />
    </pl.waw.oledzki.wptr.PlateLayout>

    <TextView
        android:id="@+id/dateText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/date_text"
        android:layout_marginTop="4dp" />

</LinearLayout>
